    "test": "vitest run"
  },
  "dependencies": {
    "@trust-zones/sdk": "workspace:*",
    "@trust-zones/compiler": "workspace:*",
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "viem": "^2.28.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
